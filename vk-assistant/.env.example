# 1. Для личного бота нужен USER ACCESS TOKEN (не сервисный ключ!)
# Получить тут: https://vkhost.github.io/ (выбрать VK Admin / Kate Mobile)
# Нужные права: messages, friends, groups, wall, offline
VK_USER_TOKEN=your_user_access_token_here

# 2. ID приложения (опционально, для логов)
VK_APP_ID=your_app_id_here

# 3. Сервисный ключ — только для публичных данных групп
VK_SERVICE_TOKEN=your_service_token_here
