# AI API Configuration
# оНКСВХРЕ ЙКЧВ МЮ https://openrouter.ai/keys
AI_API_KEY=your_openrouter_api_key_here
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=deepseek/deepseek-chat

# Telegram Bot (ОНКСВХРЕ С @BotFather)
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_WEBHOOK_URL=https://yourdomain.com/api/v1/social/tg/webhook/your_bot_token

# VK Group (ОНКСВХРЕ Б МЮЯРПНИЙЮУ ЦПСООШ VK)
VK_GROUP_ID=your_group_id_numeric
VK_ACCESS_TOKEN=your_vk_access_token_here
VK_WEBHOOK_URL=https://yourdomain.com/api/v1/social/vk/webhook

# Telegram Client API (MTProto) ≈ МЮЯРНЪЫХИ ЮЙЙЮСМР
# оНКСВХРЕ МЮ https://my.telegram.org > API development
TELEGRAM_API_ID=your_api_id_numeric
TELEGRAM_API_HASH=your_api_hash_here