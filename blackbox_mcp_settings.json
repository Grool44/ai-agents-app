{
  "servers": {
    "github.com/postmanlabs/postman-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@postman/postman-mcp-server",
        "--minimal",
        "--quiet"
      ],
      "env": {
        "POSTMAN_API_KEY": "${POSTMAN_API_KEY}"
      }
    }
  }
}

